# Copie este arquivo para .env e preencha com suas credenciais reais
# NUNCA commite o arquivo .env no repositório

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Necessária APENAS para o script de criação em massa (scripts/criar-colaboradores.mjs).
# Pegue em: painel Supabase → Settings → API → service_role.
# É SECRETA (ignora RLS): nunca use no front-end nem commite o .env.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
